<%= semantic_form_for MessageDistribution::SendingForm.new, :url => submit_sending_admin_message_distribution_path(resource) do |f| %>
  <%= f.inputs :name => 'Сегмент получателей', :class => 'inputs' do %>

    <p>
      Активных пользователей: <strong><%= TelegramUser.active.count %></strong>,
      активных чатов: <strong><%= TelegramChat.active.count %></strong>.
      Итоговая выборка зависит от фильтров ниже.
    </p>

    <%= f.input :send_to_users, as: :boolean %>

    <%= f.input :send_to_chats, as: :boolean,
                hint: "По умолчанию в чаты не отправляем" %>

    <%= f.input :only_active, as: :boolean,
                hint: "Исключить тех, кто заблокировал/удалил бота" %>

    <%= f.input :active_since,
                as: :date_time_picker,
                picker_options: { timepicker: true },
                input_html: { size: 500 },
                hint: "Был онлайн не раньше этой даты (по last_seen_at)" %>

    <%= f.input :min_command_count,
                as: :number,
                hint: "Минимальное число запросов к боту (пусто — без ограничения)" %>
  <% end %>

  <%= f.inputs :name => 'Тестовая отправка', :class => 'inputs' do %>

    <%= f.input :test_sending, as: :boolean,
                hint: "Отправит сообщение только выбранным ниже пользователям, без записи статистики и без смены статуса рассылки" %>

    <%= f.input :test_telegram_user_ids,
                as: :select,
                collection: [],
                input_html: {
                  multiple: true,
                  class: 'autocomplete-select',
                  'data-autocomplete-url' => autocomplete_admin_telegram_users_path,
                } %>

    <%= f.input :test_telegram_chat_ids,
                as: :string,
                label: "Тестовые чаты (external id)",
                hint: "ID чатов через запятую или пробел, например: -1001234567890" %>
  <% end %>

  <fieldset class="actions">
    <%= f.submit "Отправить", class: "btn btn-success" %>
    <%= link_to 'Cancel', resource_path(resource), class: "action btn btn-danger" %>
  </fieldset>
<% end %>
